def handle_read(tokens):
    if len(tokens) != 2:
        print("ERROR")
        return
    file_path = Path(tokens[1])
    
    if not file_path.exists() or not file_path.is_file() or file_path.suffix != ".dsu":
        print("ERROR")
        return

    try:
        content = file_path.read_text()
        if content == "":
            print("EMPTY")
        else:
            print(content)
    except Exception:
        print("ERROR")
