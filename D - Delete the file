def handle_delete(tokens):
    if len(tokens) != 2:
        print("ERROR")
        return

    file_path = Path(tokens[1])
    
    if not file_path.exists() or file_path.suffix != ".dsu":
        print("ERROR")
        return
    try:
        file_path.unlink()
        print(f"{file_path} DELETED")
    except Exception:
        print("ERROR")
